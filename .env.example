# Local port bindings
VC4_HTTP_PORT=8847
VC4_HTTPS_PORT=8848
VC4_FLASH_POLICY_EXTERNAL_PORT=843
VC4_CIP_TCP_PORT=41794
VC4_CIP_UDP_PORT=41794
VC4_SECURE_CIP_PORT=41796
VC4_HTML5_XPANEL_PORT=49200

# Coolify/private-registry deployments
VC4_IMAGE=registry.example.com/vc4-docker:latest

# Docker-specific behavior
VC4_SHM_SIZE=512m
VC4_DISABLE_FRONTEND_LOCALHOST_MOCKS=true
VC4_ENABLE_RESTART_SERVICE_SHIM=true
VC4_ENABLE_STARTUP_COMPAT_SHIMS=true
VC4_ENABLE_APPWATCHDOG_REBOOT_SHIM=true

# Optional TLS certs mounted under /run/vc4-hardening
VC4_TLS_CERT_FILE=
VC4_TLS_KEY_FILE=

# Optional Flash policy server config: disabled, secure, or unsecure
VC4_FLASH_POLICY_MODE=
VC4_FLASH_POLICY_DOMAIN=*
VC4_FLASH_POLICY_PORT=1025

# Optional PAM-backed HTTP Basic auth
VC4_PAM_REQUIRE_SSL=true
VC4_PAM_ADMIN_ENABLED=false
VC4_PAM_ADMIN_USERNAME=
VC4_PAM_ADMIN_PASSWORD=
VC4_PAM_STATUS_ENABLED=false
VC4_PAM_STATUS_USERNAME=
VC4_PAM_STATUS_PASSWORD=
VC4_PAM_ROOM_CREDENTIALS_FILE=
